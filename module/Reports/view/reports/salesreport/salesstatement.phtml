							<th>Cash Gross</th>
							<th>Cash Dis</th>
							<th>Net Cash</th>
							<th>Credit Gross</th>
							<th>Credit Dis</th>
							<th>Net Credit</th>
							<th>Total Gross</th>
							<th>Total Net</th>
						</tr>
					</thead>
					<tbody>	
						<?php
							$sl = 1;
							$sum_cash_gross = 0;
							$sum_cash_dis = 0;
							$sum_net_cash = 0;
							$sum_credit_gross = 0;
							$sum_credit_dis = 0;
							$sum_net_credit = 0;
							$sum_total_gross = 0;
							$sum_total_net = 0;
							$locations = $this->salesObj->getSalesLocation($data, 'sales_date');
							foreach($locations as $location):
								//echo "<pre>";print_r($location);
								$cash_gross = $this->salesObj->getSalesStatementGross($data, $location['location'], 'sales_date','0');
								$credit_gross = $this->salesObj->getSalesStatementGross($data, $location['location'], 'sales_date','1');
								
								$cash_dis = $this->salesObj->getSalesStatementDis($data, $location['location'], 'sales_date','0');
								$credit_dis = $this->salesObj->getSalesStatementDis($data, $location['location'], 'sales_date','1');
								
								$net_cash = $cash_gross - $cash_dis;
								$net_credit = $credit_gross - $credit_dis;
								
								$total_gross = $cash_gross + $credit_gross;
								$total_net = $net_cash + $net_credit;
								
								$sum_cash_gross += $cash_gross;
								$sum_cash_dis += $cash_dis;
								$sum_net_cash += $net_cash;
								$sum_credit_gross += $credit_gross;
								$sum_credit_dis += $credit_dis;
								$sum_net_credit += $net_credit;
								$sum_total_gross += $total_gross;
								$sum_total_net += $total_net;
								
								//If the Amount is Empty
								$cash_gross = ($cash_gross == '')?'-':number_format($cash_gross,'2','.',',');
								$cash_dis = ($cash_dis == '')?'-':number_format($cash_dis,'2','.',',');
								$net_cash = ($net_cash == '')?'-':number_format($net_cash,'2','.',',');
								$credit_gross = ($credit_gross == '')?'-':number_format($credit_gross,'2','.',',');
								$credit_dis = ($credit_dis == '')?'-':number_format($credit_dis,'2','.',',');
								$net_credit = ($net_credit == '')?'-':number_format($net_credit,'2','.',',');
								$total_gross = ($total_gross == '')?'-':number_format($total_gross,'2','.',',');
								$total_net = ($total_net == '')?'-':number_format($total_net,'2','.',',');
						?>
						<tr>
							<td><?php echo $sl++;?></td>
							<td><?php echo $location['location_name'];?></td>
							<td><?php echo $cash_gross;?></td>
							<td><?php echo $cash_dis;?></td>
							<td><?php echo $net_cash;?></td>
							<td><?php echo $credit_gross;?></td>
							<td><?php echo $credit_dis;?></td>
							<td><?php echo $net_credit;?></td>
							<td><?php echo $total_gross;?></td>
							<td><?php echo $total_net;?></td>
						</tr>
						<?php endforeach;?>
						<tr style="border-top:3px solid #ddd;border-bottom:3px solid #ddd;">
							<td colspan='2'><strong>Total</strong></td>
							<td><strong><?php echo number_format($sum_cash_gross, 2, '.', ',');?></strong></td>
							<td><strong><?php echo number_format($sum_cash_dis, 2, '.', ',');?></strong></td>
							<td><strong><?php echo number_format($sum_net_cash,2,'.',',');?></strong></td>
							<td><strong><?php echo number_format($sum_credit_gross, 2, '.', ',');?></strong></td>
							<td><strong><?php echo number_format($sum_credit_dis,'2','.',',');?></strong></td>
							<td><strong><?php echo number_format($sum_net_credit,'2','.',',');?></strong></td>
							<td><strong><?php echo number_format($sum_total_gross,'2','.',',');?></strong></td>
							<td><strong><?php echo number_format($sum_total_net,'2','.',',');?></strong></td>
