									$basic_quantity = ($sl_item_dtl['basic_uom']==$sl_item_dtl['sl_uom'])?$sl_item_dtl['quantity']:$sl_item_dtl['quantity']*$sale_uom_conversion;
									$basic_rate = ($sl_item_dtl['basic_uom']==$sl_item_dtl['sl_uom'])?$sl_item_dtl['rate']:$sl_item_dtl['rate']/$sale_uom_conversion;
