		$('form').formValidation('revalidateField', $(this).attr('id'));
	});
	$(function() {
			$('#print').genpdfinvoice({
		content: '#report-print',
		src:"<?php echo $this->url('pdfxls', array('action' => 'pdf'));?>",
		orentation:"L",//L =landscape, P = potrait
	});
	
	var doc_loc = $('input#region').val() + $('input#location').val() + ',' + $('input#activity').val() + ',' + $('input#payment').val()  + $('input#customer').val() + '(from: '+$('input#start_date').val()+' to: '+$('input#end_date').val()+')';
		$("#excel").click(function(){
		  $("#table2excel").table2excel({
			// exclude CSS class
			exclude: ".noExl",
			name: "Worksheet Name",
			filename: "Slesregister_for_"+doc_loc, //do not include extension
		  }); 
		});
		//get location by region
		$('#region').on('change',function(){
			$.post(
				'<?php echo $this->url('salesreport',array('action'=>'getlocation'));?>',
				{
					'region' : $(this).val(),
				},
				function(data){
					//console.log(data);
					$('#location').html(data.location);
					$('#location option:selected').removeAttr('selected');
					$('#location').trigger('chosen:updated');
				},
				'json'
			);
		});
		//get customer if it is credit
		$('#payment').on('change',function(){
			$.post(
				'<?php echo $this->url('salesreport',array('action'=>'getcustomer'));?>',
				{
					'payment' : $(this).val(),
				},
				function(data){
					//console.log(data);
					$('#customer').html(data.customer);
					$('#customer option:selected').removeAttr('selected');
					$('#customer').trigger('chosen:updated');
				},
				'json'
			);
		});
	/*** Form Validation ***/
	$('form').formValidation({
			framework: 'bootstrap',
			excluded: ':disabled',
			message: 'This value is not valid',
			fields: {
				'region': {
					validators: {
						notEmpty: {
							message: 'Please select region'
						}
					}
				},
				'location': {
					validators: {
						notEmpty: {
							message: 'Please select location'
						}
					}
				},
				'activity': {
					validators: {
						notEmpty: {
							message: 'Please select activity'
						}
					}
				},
				'itemgroup': {
					validators: {
						notEmpty: {
							message: 'Please select item group'
						}
					}
				},
				'start_date': {
					validators: {
						notEmpty: {
							message: 'Please select start date'
						}
					}
				},
				'end_date': {
					validators: {
						notEmpty: {
							message: 'Please select end date'
						}
					}
				},
				'payment': {
					validators: {
						notEmpty: {
							message: 'Please select cash/credit/all'
						}
					}
				},
				'customer': {
					validators: {
						notEmpty: {
							message: 'Please select customer'
						}
					}
				},
			}
		}).on('success.field.fv', function(e, data) {
			if (data.fv.getInvalidFields().length > 0) {    // There is invalid field
				data.fv.disableSubmitButtons(true);
			}
		});
	});
