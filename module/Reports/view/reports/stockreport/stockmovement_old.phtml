							$op_in_receipt = $this->dispatchObj->getSMOpeningSUM($data['start_date'],$data['location'],array('dd.item'=>$item['item_id'],'d.status'=>3),'d.received_on','d.to_location','dd.accepted_qty',$openingDate);
							
