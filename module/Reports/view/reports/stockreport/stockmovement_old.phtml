							$op_converted_from = $this->itemconversionObj->getSMOpeningSUM($data['start_date'],$data['location'],array('item'=>$item['item_id'],'status'=>3),'conversion_date','location','basic_qty');
							
							$op_credit = $this->salesObj->getSMOpeningSUM($data['start_date'],$data['location'],array('sd.item'=>$item['item_id'],'credit'=>1,'s.status'=>3),'s.sales_date','s.location','sd.basic_quantity');
							$op_cash = $this->salesObj->getSMOpeningSUM($data['start_date'],$data['location'],array('sd.item'=>$item['item_id'],'credit'=>0,'s.status'=>3),'s.sales_date','s.location','sd.basic_quantity');
							
							$op_dump = $this->samObj->getSMOpeningSUM($data['start_date'],$data['location'],array('sd.item'=>$item['item_id'],'sam_type'=>array(1,2),'s.status'=>3),'s.sam_date','s.location','sd.basic_quantity');
							$op_shortage = $this->samObj->getSMOpeningSUM($data['start_date'],$data['location'],array('sd.item'=>$item['item_id'],'sam_type'=>3,'s.status'=>3),'s.sam_date','s.location','sd.basic_quantity');
							$op_sales_promotion = $this->samObj->getSMOpeningSUM($data['start_date'],$data['location'],array('sd.item'=>$item['item_id'],'sam_type'=>4,'s.status'=>3),'s.sam_date','s.location','sd.basic_quantity');
							$op_adjustment = $this->samObj->getSMOpeningSUM($data['start_date'],$data['location'],array('sd.item'=>$item['item_id'],'sam_type'=>5,'s.status'=>3),'s.sam_date','s.location','sd.basic_quantity');
							
							$plus_opening = $op_stock_openings + $op_purchases + $op_adjustment + $op_in_receipt + $op_converted_to;
							$minus_opening = $op_dispatch + $op_converted_from + $op_credit + $op_cash + $op_dump + $op_shortage + $op_sales_promotion;
							$opening = $plus_opening - $minus_opening;
							
							//Purchase Receipt Table
							$purchases = $this->pur_receiptObj->getSMQuantitySUM($data['start_date'],$data['end_date'],$data['location'],array('pd.item'=>$item['item_id'],'p.status'=>3),'p.prn_date','p.location','pd.basic_sound_qty');
							//Dispatch Table
							$dispatch = $this->dispatchObj->getSMQuantitySUM($data['start_date'],$data['end_date'],$data['location'],array('dd.item'=>$item['item_id'],'d.status'=>array(2,10,3)),'d.dispatch_date','d.from_location','dd.basic_quantity');
							$in_receipt = $this->dispatchObj->getSMQuantitySUM($data['start_date'],$data['end_date'],$data['location'],array('dd.item'=>$item['item_id'],'d.status'=>3),'d.received_on','d.to_location','dd.accepted_qty');
							$in_transit = $this->dispatchObj->getSMIntransitQtySUM($data['end_date'],$data['location'],array('dd.item'=>$item['item_id'],'d.status'=>array(10,2)),'d.dispatch_date','d.to_location','dd.basic_quantity',$openingDate);
							//Item Conversion
							$converted_to = $this->itemconversionObj->getSMQuantitySUM($data['start_date'],$data['end_date'],$data['location'],array('converted_item'=>$item['item_id'],'status'=>3),'conversion_date','location','converted_basic_qty');
							$converted_from = $this->itemconversionObj->getSMQuantitySUM($data['start_date'],$data['end_date'],$data['location'],array('item'=>$item['item_id'],'status'=>3),'conversion_date','location','basic_qty');
							//Sales Table
							$credit = $this->salesObj->getSMQuantitySUM($data['start_date'],$data['end_date'],$data['location'],array('sd.item'=>$item['item_id'],'credit'=>1,'s.status'=>3),'s.sales_date','s.location','sd.basic_quantity');
							$cash = $this->salesObj->getSMQuantitySUM($data['start_date'],$data['end_date'],$data['location'],array('sd.item'=>$item['item_id'],'credit'=>0,'s.status'=>3),'s.sales_date','s.location','sd.basic_quantity');
							//SAM Table
							$dump = $this->samObj->getSMQuantitySUM($data['start_date'],$data['end_date'],$data['location'],array('sd.item'=>$item['item_id'],'sam_type'=>array(1,2),'s.status'=>3),'s.sam_date','s.location','sd.basic_quantity');
							$shortage = $this->samObj->getSMQuantitySUM($data['start_date'],$data['end_date'],$data['location'],array('sd.item'=>$item['item_id'],'sam_type'=>3,'s.status'=>3),'s.sam_date','s.location','sd.basic_quantity');
							$sales_promotion = $this->samObj->getSMQuantitySUM($data['start_date'],$data['end_date'],$data['location'],array('sd.item'=>$item['item_id'],'sam_type'=>4,'s.status'=>3),'s.sam_date','s.location','sd.basic_quantity');
							$adjustment = $this->samObj->getSMQuantitySUM($data['start_date'],$data['end_date'],$data['location'],array('sd.item'=>$item['item_id'],'sam_type'=>5,'s.status'=>3),'s.sam_date','s.location','sd.basic_quantity');
							
							//Adjusted - sum of $shorage and $converted from
							$adjusted = $shortage + $converted_from + $adjustment + $sales_promotion;
							//Sum of $converted_to and $in_receipt
							$int_conv = $in_receipt + $converted_to;
							
							//Closing Balance
							$closing = $opening + $purchases + $in_receipt + $adjustment - $dispatch + $converted_to - $converted_from - $dump - $shortage - $cash - $credit - $sales_promotion; 
							if($opening == 0 && $purchases == 0 && $in_receipt == 0 && $dispatch == 0 && $dump == 0 && $shortage == 0 && $adjustment == 0 && $cash == 0 && $credit== 0 && $in_transit == 0 && $converted_to == 0 && $converted_from == 0 && $sales_promotion == 0):
						?>
						<?php else:
								$opening = ($opening != '' && $opening != 0)?number_format($opening, 2, '.', ','):'-';
								$purchases = ($purchases != '' && $purchases != 0)?number_format($purchases, 2, '.', ','):'-';
								$in_receipt = ($in_receipt != '' && $in_receipt != 0)?number_format($in_receipt, 2, '.', ','):'-';
								$dispatch = ($dispatch != '' && $dispatch != 0)?number_format($dispatch, 2, '.', ','):'-';
								$converted_to = ($converted_to != '' && $converted_to != 0)?number_format($converted_to, 2, '.', ','):'-';
								$converted_from = ($converted_from != '' && $converted_from != 0)?number_format($converted_from, 2, '.', ','):'-';
								$dump = ($dump != '' && $dump != 0)?number_format($dump, 2, '.', ','):'-';
								$shortage = ($shortage != '' && $shortage != 0)?number_format($shortage, 2, '.', ','):'-';
								$credit = ($credit != '' && $credit != 0)?number_format($credit, 2, '.', ','):'-';
								$cash = ($cash != '' && $cash != 0)?number_format($cash, 2, '.', ','):'-';
								$in_transit = ($in_transit != '' && $in_transit != 0)?number_format($in_transit, 2, '.', ','):'-';
								$adjusted = ($adjusted != '' && $adjusted != 0)?number_format($adjusted, 2, '.', ','):'-';
								$int_conv = ($int_conv != '' && $int_conv != 0)?number_format($int_conv, 2, '.', ','):'-';
							?>
							<tr>
								<td><?php echo $item['code'];?></td>
								<?php if($data['activity'] == '1' || $data['activity'] == '7'): ?>
								<td><?php echo $this->partyObj->getColumn($item['supplier'],'code');?></td>
								<td><?php echo 'NA';?></td>
								<?php endif;?>
								<td class="blue" style="text-align:right" title="<?php echo "Opening : ".$op_stock_openings."&#013Purchase : ".$op_purchases."&#013IntRecpt : ".$op_in_receipt."&#013Convert To : ".$op_converted_to."&#013Convert From : ".$op_converted_from."&#013Dispatch : ".$op_dispatch."&#013Dumped : ".$op_dump."&#013Shortage : ".$op_shortage."&#013Credit : ".$op_credit."&#013Cash : ".$op_cash;?>">
									<?php echo $opening;?></td>
								<td class="green" style="text-align:right"><?php echo $purchases;?></td>
								<td class="green" style="text-align:right" title="<?php echo "IntRecpt : ".$in_receipt."&#013Converted To : ".$converted_to;?>"><?php echo $int_conv;?></td>
								<td class="red" style="text-align:right"><?php echo $dispatch;?></td>
								<td class="red" style="text-align:right"><?php echo $dump; ?></td>
								<td class="red" style="text-align:right" title="<?php echo "Shortage : ".$shortage."&#013Converted From : ".$converted_from."&#013Adjustment : ".$adjustment;?>"><?php echo $adjusted; ?></td>
								<td class="red" style="text-align:right"><?php echo $credit;?></td>
								<td class="red" style="text-align:right"><?php echo $cash;?></td>
								<td class="purple" style="text-align:right"><?php echo $in_transit;?></td>
								<td class="blue" style="text-align:right"><?php echo ($closing != '' && $closing != 0)?number_format($closing, 2, '.', ','):'-';;?></td>
								<td class="orange"><?php echo $total_qty;?></td>
								<td style="text-align:right"><?php echo number_format($moving_elc, 2, '.', ',');?></td>
								<td style="text-align:right"><?php echo number_format($moving_sp, 2, '.', ',');?></td>
								<td style="text-align:right"><?php 
										$sv = $closing * $moving_elc;
										echo number_format($sv, 2, '.', ',');
									?>
								</td>
							</tr>
						<?php 
								endif;
						endforeach;
					endif;	
					?>
				</tbody>
			</table>
		</div>
	</div>
</div>
<?php
	$time = microtime();
