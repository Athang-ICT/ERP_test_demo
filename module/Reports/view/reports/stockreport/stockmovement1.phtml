								$total_stock_intransit_value += $siv;
						       
						        $credit_value = $credit * $moving_sp;
						        $total_credit_value += $credit_value;
						        $cash_value = $cash * $moving_sp;
						        $total_cash_value += $cash_value;
						        $sum_closing += $closing;
						        
								$opening = ($opening != '' && $opening != 0)?number_format($opening, 2, '.', ''):'0';
								$purchases = ($purchases != '' && $purchases != 0)?number_format($purchases, 2, '.', ''):'0';
								$in_receipt = ($in_receipt != '' && $in_receipt != 0)?number_format($in_receipt, 2, '.', ''):'0';
								$dispatch = ($dispatch != '' && $dispatch != 0)?number_format($dispatch, 2, '.', ''):'0';
