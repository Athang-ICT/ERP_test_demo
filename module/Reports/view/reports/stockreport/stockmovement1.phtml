								$converted_from = ($converted_from != '' && $converted_from != 0)?number_format($converted_from, 2, '.', ''):'0';
								$dump = ($dump != '' && $dump != 0)?number_format($dump, 2, '.', ''):'0';
								$shortage = ($shortage != '' && $shortage != 0)?number_format($shortage, 2, '.', ''):'0';
								$credit = ($credit != '' && $credit != 0)?number_format($credit, 2, '.', ''):'0';
								$cash = ($cash != '' && $cash != 0)?number_format($cash, 2, '.', ''):'0';
								$in_transit = ($in_transit != '' && $in_transit != 0)?number_format($in_transit, 2, '.', ''):'0';
								$adjusted = ($adjusted != '' && $adjusted != 0)?number_format($adjusted, 2, '.', ''):'0';
								$int_conv = ($int_conv != '' && $int_conv != 0)?number_format($int_conv, 2, '.', ''):'0';
							?>
							<tr>
								<td><?php echo $item['code'];?></td>
								<?php if($data['activity'] == '1' || $data['activity'] == '7'): ?>
