	};
	
	function pol_loop_next(obj,input_obj){
		var id = input_obj.closest('tr').attr('id');
		var lastRow = obj.find("tbody tr:last").attr('id');
		
		if(id <= lastRow){
			var next_id = input_obj.closest('tr').next().attr('id');
            //alert(lastRow);exit;
			do{
				$('#initial_reading-'+next_id).val($('#final_reading-'+id).val());
				$('#opening_tank_balance-'+next_id).val($('#closing_tank_balance-'+id).val());
				$('#total_fuelling-'+next_id).val($('#closing_tank_balance-'+id).val());
				
				var final_reading = parseFloat($('#final_reading-'+next_id).val()).toFixed(2);
				var initial_reading = parseFloat($('#initial_reading-'+next_id).val()).toFixed(2);
				var km_covered = final_reading - initial_reading;
				$('#km_covered-'+next_id).val(parseFloat(km_covered).toFixed(2));
				
				var km_covered = parseFloat($('#km_covered-'+next_id).val()).toFixed(2);
				var fuel_consumed = parseFloat($('#fuel_consumed-'+next_id).val()).toFixed(2);
				if(fuel_consumed > 0){
					var millage = km_covered / fuel_consumed;
					$('#millage-'+next_id).val(parseFloat(millage).toFixed(2));
					
					
					var total_fuelling = parseFloat($('#total_fuelling-'+next_id).val()).toFixed(2);
					var fuel_consumed = $('#fuel_consumed-'+next_id).val();
					var closing_tank_balance = total_fuelling - fuel_consumed;
					$('#closing_tank_balance-'+next_id).val(parseFloat(closing_tank_balance).toFixed(2));
				}else{
					$('#millage-'+next_id).val('0.00');
					$('#closing_tank_balance-'+next_id).val('0.00');
				}
				id = $('#initial_reading-'+next_id).closest('tr').attr('id');
				next_id = $('#initial_reading-'+next_id).closest('tr').next().attr('id');
				
			}while(next_id <= lastRow);
			
		}
	}
	function pol_loop(obj,input_obj){
		var id = input_obj.closest('tr').attr('id');
		var lastRow = obj.find("tbody tr:last").attr('id');
		var firstRow = obj.find("tbody tr:first").attr('id');
		if(id <= lastRow){
          
			var next_id = input_obj.closest('tr').next().attr('id');
			var prev_id = input_obj.closest('tr').prev().attr('id');
			do{
				if(firstRow == id){
					$('#initial_reading-'+next_id).val($('#last_km_reading').val());
					$('#opening_tank_balance-'+next_id).val($('#tank_balance').val());
					
					var final_reading = parseFloat($('#final_reading-'+next_id).val()).toFixed(2);
					var initial_reading = parseFloat($('#last_km_reading').val()).toFixed(2);
					var km_covered = final_reading - initial_reading;
					
					var total_fuelling = parseFloat($('#refuelling-'+next_id).val()) + parseFloat($('#tank_balance').val());
					
					$('#km_covered-'+next_id).val(parseFloat(km_covered).toFixed(2));
					$('#total_fuelling-'+next_id).val(parseFloat(total_fuelling).toFixed(2));
				}else{
					//alert(id); exit;
					$('#initial_reading-'+next_id).val($('#final_reading-'+prev_id).val());
					$('#opening_tank_balance-'+next_id).val($('#closing_tank_balance-'+prev_id).val());
					
					var total_fuelling = parseFloat($('#refuelling-'+next_id).val()) + parseFloat($('#closing_tank_balance-'+prev_id).val());
					var final_reading = parseFloat($('#final_reading-'+next_id).val()).toFixed(2);
					var initial_reading = parseFloat($('#final_reading-'+prev_id).val()).toFixed(2);
					var km_covered = final_reading - initial_reading;
					$('#km_covered-'+next_id).val(parseFloat(km_covered).toFixed(2));
					$('#total_fuelling-'+next_id).val(parseFloat(total_fuelling).toFixed(2));
				}
				
				var km_covered = parseFloat($('#km_covered-'+next_id).val()).toFixed(2);
				var fuel_consumed = parseFloat($('#fuel_consumed-'+next_id).val()).toFixed(2);
				if(fuel_consumed > 0){
					var millage = km_covered / fuel_consumed;
					$('#millage-'+next_id).val(parseFloat(millage).toFixed(2));
					
					var total_fuelling = parseFloat($('#total_fuelling-'+next_id).val()).toFixed(2);
					var fuel_consumed = $('#fuel_consumed-'+next_id).val();
					var closing_tank_balance = total_fuelling - fuel_consumed;
					$('#closing_tank_balance-'+next_id).val(parseFloat(closing_tank_balance).toFixed(2));
				}else{
					$('#millage-'+next_id).val('0.00');
					$('#closing_tank_balance-'+next_id).val('0.00');
				}
				id = $('#initial_reading-'+next_id).closest('tr').attr('id');
				next_id = $('#initial_reading-'+next_id).closest('tr').next().attr('id');
				prev_id = $('#initial_reading-'+next_id).closest('tr').prev().attr('id');
				
			}while(next_id <= lastRow);
		}
	}
	function pol_delbtn(obj){
		if(obj.find("tbody tr").length > 1){
			delBtn = "<a value='Delete' class='btn btn-warning btn-xs delRow' style='margin-top:5px;' ><i class='fa fa-times'></i></a>";
			obj.find("tbody tr").each(function(){
				$(this).find("td:last").html(delBtn);			
			});
			obj.find("td a.delRow").each(function(){
				$(this).click(function(){pol_delrow($(this).closest('tr'));});	
			});
		}else{
			delBtn = "<a value='Delete' class='btn btn-warning btn-xs resetRow' style='margin-top:5px;' ><i class='fa fa-refresh'></i></a>";
			obj.find("tbody tr").each(function(){
				var las_td = $(this).find("td:last").html(delBtn);
			});
			obj.find("td a.resetRow").each(function(){
				$(this).click(function(){pol_reset($(this).closest('tr'));});	
			});
		}	
	};	
	function pol_delrow(obj){
		obj.find(':input[data-fv-field]').each(function() {
			$('form').formValidation('removeField', $(this));
		});	
		pol_loop(obj.parent().parent().parent().parent(),obj);
		var tr_length = obj.parent().find('tr').length;
		var tbody = obj.parent();
		obj.closest("tr").remove();	
		if(tr_length == 2){
			var delBtn = "<a value='Delete' class='btn btn-warning btn-xs resetRow' style='margin-top:5px;' ><i class='fa fa-refresh'></i></a>";
			tbody.find('tr td:last').html(delBtn);
			tbody.find('tr td:last a.resetRow').each(function(){
				$(this).click(function(){pol_reset($(this).closest("tr"));});
			});
		}
        pol_calculation(tbody.parent());
	}
	
    function pol_calculation(obj){
		obj.find('tbody tr').each(function(){
			var id = $(this).attr('id');
			
			var lastRow = obj.find("tbody tr:last").attr('id');
			var final_reading = parseFloat($('#final_reading-'+lastRow).val());
		    var closing_tank_balance = parseFloat($('#closing_tank_balance-'+lastRow).val());
			
			$('#current_km_reading').val(parseFloat(final_reading).toFixed(2));
		    $('#tank_closing').val(parseFloat(closing_tank_balance).toFixed(2));
			
			$('#refuelling-'+id).on('change',function(){pol_cal($(this).closest("tr"));});			
			$('#millage-'+id).on('change',function(){pol_cal($(this).closest("tr"));});					
			$('#fuel_consumed-'+id).on('change',function(){pol_cal($(this).closest("tr"));});	
			$('#final_reading-'+id).on('change',function(){pol_cal($(this).closest("tr"));});				
			$('#r_rate-'+id).on('change',function(){pol_cal($(this).closest("tr"));});				
		});
		
		var net_refuelling = 0;
		var net_fuel_consumed = 0;
		var net_km_covered = 0;
		var net_r_amount = 0;
		
		obj.find('tbody tr').each(function(){
			var id = $(this).attr('id');
			net_fuel_consumed += parseFloat($('#fuel_consumed-'+id).val());
			net_refuelling += parseFloat($('#refuelling-'+id).val());
			net_km_covered += parseFloat($('#km_covered-'+id).val());
			net_r_amount += parseFloat($('#r_amount-'+id).val());
		});
		
		var net_fuel_consumed = parseFloat(net_fuel_consumed).toFixed(2);
		var net_refuelling = parseFloat(net_refuelling).toFixed(2);
		var net_km_covered = parseFloat(net_km_covered).toFixed(2);
		var net_r_amount = parseFloat(net_r_amount).toFixed(2);
		
		$('#total_refuel').val(($.isNumeric(net_refuelling))?net_refuelling:'0.00');
		$('#total_fuel_consumed').val(($.isNumeric(net_fuel_consumed))?net_fuel_consumed:'0.00');
		$('#total_kilometer').val(($.isNumeric(net_km_covered))?net_km_covered:'0.00');
		$('#amount').val(($.isNumeric(net_r_amount))?net_r_amount:'0.00');
	};
	function pol_cal(obj){
		
		var id = obj.closest("tr").attr('id');
		var lastRow = obj.parent().parent().parent().find("tbody tr:last").attr('id');
		
		var fuel_consumed = parseFloat($('#fuel_consumed-'+id).val());
		var total_fuelling = parseFloat($('#total_fuelling-'+id).val());
		var km_covered = parseFloat($('#km_covered-'+id).val());
		var final_reading = parseFloat($('#final_reading-'+id).val());
		var closing_tank_balance = parseFloat($('#closing_tank_balance-'+id).val());
        var r_amount = parseFloat($('#r_amount-'+id).val());
		
		$('#total_fuelling-'+id).val(parseFloat(total_fuelling).toFixed(2));
		$('#fuel_consumed-'+id).val(parseFloat(fuel_consumed).toFixed(2));
		$('#km_covered-'+id).val(parseFloat(km_covered).toFixed(2));
		$('#r_amount-'+id).val(parseFloat(r_amount).toFixed(2));
        
		var net_refuelling = 0;
		var net_fuel_consumed = 0;
		var net_km_covered = 0;
		var net_r_amount = 0;

		obj.parent().find('tr').each(function(){
			var id = $(this).attr('id');
			net_refuelling += parseFloat($('#refuelling-'+id).val());
			net_fuel_consumed += parseFloat($('#fuel_consumed-'+id).val());
			net_km_covered += parseFloat($('#km_covered-'+id).val());
            net_r_amount += parseFloat($('#r_amount-'+id).val());
		});

		var net_refuelling = parseFloat(net_refuelling).toFixed(2);
		var net_fuel_consumed = parseFloat(net_fuel_consumed).toFixed(2);
		var net_km_covered = parseFloat(net_km_covered).toFixed(2);
		var net_r_amount = parseFloat(net_r_amount).toFixed(2);
        
		$('#total_refuel').val(($.isNumeric(net_refuelling))?net_refuelling:'0.00');
		$('#total_fuel_consumed').val(($.isNumeric(net_fuel_consumed))?net_fuel_consumed:'0.00');
		$('#total_kilometer').val(($.isNumeric(net_km_covered))?net_km_covered:'0.00');
		$('#amount').val(($.isNumeric(net_r_amount))?net_r_amount:'0.00');
		if(lastRow){
			$('#current_km_reading').val(parseFloat(final_reading).toFixed(2));
			$('#tank_closing').val(parseFloat(closing_tank_balance).toFixed(2));
		}
	}
	function pol_reset(obj){
		var id = obj.attr('id');
		var prev_id = obj.closest('tr').prev().attr('id');
		var firstRow = obj.parent().parent().parent().find("tbody tr:first").attr('id');
		var lastRow = obj.parent().parent().parent().find("tbody tr:last").attr('id');
		if(firstRow != lastRow){
			$('#initial_reading-'+id).val($('#final_reading-'+prev_id).val());
			$('#opening_tank_balance-'+id).val($('#closing_tank_balance-'+prev_id).val());
			$('#total_fuelling-'+id).val($('#closing_tank_balance-'+prev_id).val());
		}else{
			$('#initial_reading-'+id).val($('#last_km_reading').val());
			$('#opening_tank_balance-'+id).val($('#tank_balance').val());
			$('#total_fuelling-'+id).val($('#tank_balance').val());
		}
		$('#final_reading-'+id).val('0.00');
		$('#km_covered-'+id).val('0.00');
		$('#refuelling-'+id).val('0.00');
		$('#millage-'+id).val('0.00');
		$('#fuel_consumed-'+id).val('0.00');
		$('#r_rate-'+id).val('0.00');
		$('#r_amount-'+id).val('0.00');
		$('#closing_tank_balance-'+id).val('0.00');
		
		obj.find(':input:hidden').each(function(){$(this).val('');});
		obj.find(':input[data-fv-field]').each(function() {
			$('form').formValidation('resetField',$(this));
		});	
	pol_calculation(obj.parent().parent());
	}


</script>
