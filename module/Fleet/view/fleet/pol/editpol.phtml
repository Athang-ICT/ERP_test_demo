				   },
				'json'
			);
	    });
		$('#transport').on('change',function(){
		//alert($(this).val()); 
		$.post(
				"<?php echo $this->url('pol', array('action' => 'gettransportDetails'));?>",
				{
					assets_id: $(this).val(),
				},
				function(data){
					console.log(data);
					if(data.booloan == 1){
						$('#tank_balance').attr('disabled','disabled');
						$('#last_km_reading').attr('disabled','disabled');
					}
					else{
						$('#tank_balance').attr('enabled','enabled');
						$('#last_km_reading').attr('enabled','enabled');
					}
					//$('select#transport_loc').html(data.locs);
					//$('select#transport_loc').trigger('chosen:updated');
					//$('select#transporter_fcb').html(data.driver);
					//$('select#transporter_fcb').trigger('chosen:updated');
					$('#last_km_reading').val(data.final_reading);
					$('#tank_balance').val(data.closing_tank_balance);
					$('.tr-initial_reading').val(data.final_reading);
					$('.tr-opening_tank_balance').val(data.closing_tank_balance);
					$('.tr-total_fuelling').val(data.closing_tank_balance);
				   },
				'json'
			);
	    });
		var tr_id =0;
		var parentObj = $('#trdetails_table');
		parentObj.wrap("<div style='overflow-x:scroll;margin-bottom:5px;'> </div>");
		parentObj.find("tbody tr").each(function(){
			$(this).attr('id',++tr_id);			
			$(this).find('div.chosen-search input').each(function(){
				$(this).addClass('ch-search');
			});
			$(this).find('div.chosen-container .chosen-drop').each(function(){
				$(this).css({'position':'relative'});
			});
			$(this).find(':input').not('input.ch-search').each(function(){
	            var old_id = $(this).attr('id');
	            var new_id=(old_id.lastIndexOf('-') > 0)? old_id.substr(0, old_id.lastIndexOf('-')): old_id;
	            $(this).attr('id',new_id+'-'+tr_id);
	            $(this).addClass('tr-'+new_id);
	        });
			$(this).find('input.tr-final_reading').each(function(){
				$(this).bind('change', function(){
					var id = $(this).closest('tr').attr('id');
					
					var final_reading = parseFloat($('#final_reading-'+id).val()).toFixed(2);
					var initial_reading = parseFloat($('#initial_reading-'+id).val()).toFixed(2);
					var km_covered = final_reading - initial_reading;
					$('#km_covered-'+id).val(parseFloat(km_covered).toFixed(2));
					
					var km_covered = parseFloat($('#km_covered-'+id).val()).toFixed(2);
					var fuel_consumed = parseFloat($('#fuel_consumed-'+id).val()).toFixed(2);
					var r_rate = parseFloat($('#r_rate-'+id).val()).toFixed(2);
						
					if(fuel_consumed > 0){
						var millage = km_covered / fuel_consumed;
						$('#millage-'+id).val(parseFloat(millage).toFixed(2));
						

						var total_fuelling = parseFloat($('#total_fuelling-'+id).val()).toFixed(2);
						var fuel_consumed = $('#fuel_consumed-'+id).val();
						var refuelling = $('#refuelling-'+id).val();
						var closing_tank_balance = total_fuelling - fuel_consumed;
						$('#closing_tank_balance-'+id).val(parseFloat(closing_tank_balance).toFixed(2));
						
						var r_amount = r_rate * refuelling;
						$('#r_amount-'+id).val(parseFloat(r_amount).toFixed(2));
					}else{
						$('#millage-'+id).val('0.00');
						$('#closing_tank_balance-'+id).val('0.00');
					}
					pol_loop_next(parentObj,$(this));
				});
			});
			$(this).find('input.tr-refuelling,input.tr-r_rate').each(function(){
				$(this).bind('change', function(){
					var id = $(this).closest('tr').attr('id');
					
					var total_fuelling = parseFloat($('#refuelling-'+id).val()) + parseFloat($('#opening_tank_balance-'+id).val());
					$('#total_fuelling-'+id).val(parseFloat(total_fuelling).toFixed(2));
					
					var total_fuelling = parseFloat($('#total_fuelling-'+id).val()).toFixed(2);
					var fuel_consumed = parseFloat($('#fuel_consumed-'+id).val()).toFixed(2);
					var closing_tank_balance = total_fuelling - fuel_consumed;
					$('#closing_tank_balance-'+id).val(parseFloat(closing_tank_balance).toFixed(2));
					var refuelling = parseFloat($('#refuelling-'+id).val()).toFixed(2);
					var r_rate = parseFloat($('#r_rate-'+id).val()).toFixed(2);
					if(refuelling>0){
					var r_amount = r_rate * refuelling;
					$('#r_amount-'+id).val(parseFloat(r_amount).toFixed(2));
					console.log(r_amount);
					}
					pol_loop_next(parentObj,$(this));
				});
			});
			$(this).find('input.tr-fuel_consumed').each(function(){
				$(this).bind('change', function(){
					var id = $(this).closest('tr').attr('id');
					
					var km_covered = parseFloat($('#km_covered-'+id).val()).toFixed(2);
					var fuel_consumed = parseFloat($(this).val()).toFixed(2);
					var r_rate = parseFloat($('#r_rate-'+id).val()).toFixed(2);
						
					if(fuel_consumed > 0){
						var millage = km_covered / fuel_consumed;
						$('#millage-'+id).val(parseFloat(millage).toFixed(2));
						
						var total_fuelling = parseFloat($('#total_fuelling-'+id).val()).toFixed(2);
						var fuel_consumed = $('#fuel_consumed-'+id).val();
						var closing_tank_balance = total_fuelling - fuel_consumed;
						$('#closing_tank_balance-'+id).val(parseFloat(closing_tank_balance).toFixed(2));
						
						//var r_amount = r_rate * fuel_consumed;
						//$('#r_amount-'+id).val(parseFloat(r_amount).toFixed(2));
					}else{
						$('#milage-'+id).val('0.00');
						$('#closing_tank_balance-'+id).val('0.00');
					}
					
						
					
					pol_loop_next(parentObj,$(this));
				});
			});
			pol_delbtn(parentObj);
		});
		var firstRow = parentObj.find("tbody tr:first").attr('id');
