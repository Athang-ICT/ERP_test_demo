				var fuel_consumed = parseFloat($('#fuel_consumed-'+firstRow).val()).toFixed(2);//$('#fuel_consumed-'+firstRow).val();
				var closing_tank_balance = total_fuelling - fuel_consumed;
				$('#closing_tank_balance-'+firstRow).val(parseFloat(closing_tank_balance).toFixed(2));
				
				var r_amount = r_rate * fuel_consumed;
				$('#r_amount-'+firstRow).val(parseFloat(r_amount).toFixed(2));
			}else{
				$('#millage-'+firstRow).val('0.00');
				$('#closing_tank_balance-'+firstRow).val('0.00');
			}
			pol_loop_next(parentObj,$('#final_reading-'+firstRow));
		});
		$('#tank_balance').on('change',function(){
			var firstRow = parentObj.find("tbody tr:first").attr('id');
			$('#opening_tank_balance-'+firstRow).val($(this).val());
			var total_fuelling = parseFloat($('#refuelling-'+firstRow).val()) + parseFloat($('#opening_tank_balance-'+firstRow).val());
			$('#total_fuelling-'+firstRow).val(parseFloat(total_fuelling).toFixed(2));
			
			var final_reading = parseFloat($('#final_reading-'+firstRow).val()).toFixed(2);
			var initial_reading = parseFloat($('#initial_reading-'+firstRow).val()).toFixed(2);
			var km_covered = final_reading - initial_reading;
			$('#km_covered-'+firstRow).val(parseFloat(km_covered).toFixed(2));
			
			var km_covered = parseFloat($('#km_covered-'+firstRow).val()).toFixed(2);
			var fuel_consumed = parseFloat($('#fuel_consumed-'+firstRow).val()).toFixed(2);
			var r_rate = parseFloat($('#r_rate-'+firstRow).val()).toFixed(2);
			if(fuel_consumed > 0){
				var millage = km_covered / fuel_consumed;
				$('#millage-'+firstRow).val(parseFloat(millage).toFixed(2));
				
				var total_fuelling = parseFloat($('#total_fuelling-'+firstRow).val()).toFixed(2);
				var fuel_consumed = parseFloat($('#fuel_consumed-'+firstRow).val()).toFixed(2);//$('#fuel_consumed-'+firstRow).val();
				var closing_tank_balance = total_fuelling - fuel_consumed;
				$('#closing_tank_balance-'+firstRow).val(parseFloat(closing_tank_balance).toFixed(2));
				
				//var r_amount = r_rate * fuel_consumed;
				//$('#r_amount-'+firstRow).val(parseFloat(r_amount).toFixed(2));
			}else{
				$('#millage-'+firstRow).val('0.00');
				$('#closing_tank_balance-'+firstRow).val('0.00');
			}
			pol_loop_next(parentObj,$('#final_reading-'+firstRow));
		});
		if($('#addRow').length == 0){
			var addbutton = "<div class='row'><div class='col-lg-12'><a value='Add' id='addRow' class='pull-right btn btn-success btn-xs' ><i class='fa fa-plus'></i> Add Row</a>&nbsp;&nbsp;&nbsp;&nbsp;</div></div>";
			parentObj.parent().parent().parent().append(addbutton);
		};		
		$("#addRow").click(function(){
			pol_addrow(parentObj);			     
		});
        pol_calculation(parentObj);				
	});	
	function pol_addrow(obj){
