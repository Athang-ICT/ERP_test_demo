    var relatedItemElement = $(this).closest('tr').find('.tr_item');

    $.post(
        "<?php echo $this->url('vehicle', array('action' => 'gettransport')); ?>",
        {
            serviceId: selectedService,
            locationId: selectedLocation,
        },
        function(data) {
            relatedItemElement.html(data.item);
