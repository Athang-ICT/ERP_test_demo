<script type="text/javascript">	 
    $(function(){
		$('#issue_date').datepicker();
		$('#issue_date').on('changeDate',function(){
			$('form').formValidation('revalidateField', $(this).attr('id'));
		});
	    $('#trdetails_table').requisition({
			getUom:"<?php echo $this->url("vehicle", array("action" => "getUom"));?>",
		});
	    $('#transport').on('change',function(){
		//alert($(this).val()); 
		$.post(
			"<?php echo $this->url('vehicle', array('action' => 'gettransportDetails'));?>",
			{
				assets_id: $(this).val(),
			},
			function(data){
				//console.log(data);
				$('select#location').html(data.locs);
				$('select#location').trigger('chosen:updated');
				$('select#transporter_fcb').html(data.driver);
				$('select#transporter_fcb').trigger('chosen:updated');
			   },
			'json'
		    );
	    });
	    /*** Form Validation of RM ***/
		const fv = FormValidation.formValidation(document.getElementById('#form'), {
			fields: {
				issue_date: {
					validators: {
						notEmpty: {
							message: 'Please select issue date'
						}
					}
				},
				transport: {
					validators: {
						notEmpty: {
							message: 'Please select transport'
						}
					}
				},
				item[]: {
					validators: {
						notEmpty: {
							message: 'Please select item'
						}
					}
				},
				uom[]: {
					validators: {
						notEmpty: {
							message: 'Please select uom'
						}
					}
				},
				quantity[]: {
					validators: {
						notEmpty: {
							message: 'Please provide quantity'
						}
					}
				},
			},
			plugins: {
				trigger: new FormValidation.plugins.Trigger(),
				bootstrap3: new FormValidation.plugins.Bootstrap3(),
				submitButton: new FormValidation.plugins.SubmitButton(),
				defaultSubmit: new FormValidation.plugins.DefaultSubmit(),
			},
		}).on('core.element.validated', function (e) {
			if (e.valid) {
				$('div#'+ e.field.replace('[]','') +'_chosen').removeClass('is-invalid');
				$('div#'+ e.field.replace('[]','') +'_chosen').addClass('is-valid');
			} else {
				$('div#'+ e.field.replace('[]','') +'_chosen').removeClass('is-valid');
				$('div#'+ e.field.replace('[]','') +'_chosen').addClass('is-invalid');
			}
		});

	});    
</script>
