	$(document).on('input', '.tr_amount,.tr_quantity', function () {
		calculateTotalAmount();
		});
	$(document).on('input', '.tr_rate, .tr_quantity', function() {
		calculateTotal($(this));
	});
	function calculateTotal(element) {
		var row = element.closest('tr');  // Get the closest table row

		var rateInput = row.find('.tr_rate');  // Adjusted these to use class selectors and scope within the row
		//var quantityInput = row.find('.tr_quantity');
		var totalInput = row.find('.tr_amount'); // Assuming there's a field for the total amount with the class "tr_amount"

		var rate = parseFloat(rateInput.val()) || 0;
		//var quantity = parseFloat(quantityInput.val()) || 0;
		var total = rate ;

		totalInput.val(total.toFixed(2));  // Assuming you want to show up to two decimal places
		calculateTotalAmount();
	}
	function calculateTotalAmount() {
		console.log("calculateTotal amount");
		var total = 0.0;

		// Iterate over each amount input field in the table
		$('.tr_amount').each(function() {
			var amount = parseFloat($(this).val());
			if (!isNaN(amount)) { // Make sure it's a valid number
				total += amount;
			}
		});

		// Update the #total field with the new sum
		$('#rm_amount').val(total.toFixed(2));
	}	
