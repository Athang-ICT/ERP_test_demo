			<tbody>							
				<?php $i = 1; 
				foreach ($po_details as $po_detail):?>
					<tr>
						<td><?php echo $i++; ?> </td>
						<td><?php echo $po_detail['item']; ?></td>
						<td><?php echo $po_detail['uom']; ?></td>
						<td><?php echo $po_detail['quantity']; ?></td>
						<td><?php echo $po_detail['rate']; ?></td>
						<?php $pr_receipts = $this->prnObj->get(array('purchase_order' => $po_id));
							$sum_qty = 0;
							foreach($pr_receipts as $pr_receipt): 
								$prn_qty = $this->prndtlsObj->getColumn(array('purchase_receipt'=>$pr_receipt['id'],'item'=>$po_detail['item_id'],'po_details_id'=>$po_detail['id']),'challan_qty');
								$prn_uom = $this->prndtlsObj->getColumn(array('purchase_receipt'=>$pr_receipt['id'],'item'=>$po_detail['item_id'],'po_details_id'=>$po_detail['id']),'uom');
								$basic_uom = $this->itemObj->getColumn($po_detail['item_id'],'uom');
								$prn_uom_conversion = $this->itemuomObj->getColumn(array('item'=>$po_detail['item_id'],'uom'=>$prn_uom),'conversion');
								$prn_uom_conversion = (!is_numeric($prn_uom_conversion))?"1":$prn_uom_conversion;
								
								$po_uom_conversion = $this->itemuomObj->getColumn(array('item'=>$po_detail['item_id'],'uom'=>$po_detail['uom_id']),'conversion');
								$po_uom_conversion = (!is_numeric($po_uom_conversion))?"1":$po_uom_conversion;
								
								$basic_prn_qty = ($prn_uom == $basic_uom)?$prn_qty: $prn_qty * $prn_uom_conversion;
								$converted_qty = ($basic_uom == $po_detail['uom_id'])?$basic_prn_qty: $basic_prn_qty / $po_uom_conversion;
								$sum_qty += $converted_qty;
						?>
							<td><?php echo ($converted_qty == 0)?'-':$converted_qty;?></td>
						<?php endforeach;?>
						<td><?php echo $sum_qty;?></td>
						<td><?php echo $po_detail['quantity'] - $sum_qty;?></td>
