		<?php 
			$po_details = $this->podtlObj->get(array('purchase_order' => $po_id));
			if(sizeof($po_details)>0):?>
		<table class="table-condensed table-striped table-bordered table-hover" id="reportTable">
			<thead>
				<tr>
					<th>#</th>
					<th>Item</th>
					<th>Uom</th>
					<th>Qty</th>
					<th>Rate(Nu)</th>
					<?php $pr_receipts = $this->prnObj->get(array('purchase_order' => $po_id));
						foreach($pr_receipts as $pr_receipt):?>
						<th><b class="grey"><?php echo $pr_receipt['prn_no'];?><br>
						<?php echo $pr_receipt['prn_date'];?></b>
						<?php if($pr_receipt['status']==1){echo "<i class='blue'>I</i>";}elseif($pr_receipt['status']==3){echo "<i class='green'>C</i>";}else{echo "<i class='orange'>cl</i>";}?>
						<br><b class="red"><?php echo $pr_receipt['challan_no'];?></b></th>
