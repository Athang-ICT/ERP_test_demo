<script>
	$('form select').chosen();//{ allow_single_deselect: true }
	$('#repacking_date').datepicker();
	
	$('#quantity').change(function(){
		var amount = $(this).val() * $('#rate').val();
		$('#amount').val(parseFloat(amount).toFixed(2));
	});
	$('#rate').change(function(){
		var amount = $(this).val() * $('#quantity').val();
		$('#amount').val(parseFloat(amount).toFixed(2));
	});
	
	$('#activity').on('change', function(){
		$.post(
			"<?php echo $this->url("contractor", array("action" => "getitembyactivity"));?>",
			{
				activity_id: $(this).val(),
			},
			function(data){
				$("#item").html(data.stock_item);
				$("#item").trigger('chosen:updated');
			},
			'json'
		);	
	});
	
	$('#item').on('change', function(){
		$.post(
			"<?php echo $this->url("contractor", array("action" => "getuombyitem"));?>",
			{
				item_id: $(this).val(),
			},
			function(data){
				$("#uom").html(data.uoms);
				$("#uom").trigger('chosen:updated');
			},
			'json'
		);	
	});
	
	const fv = FormValidation.formValidation(document.getElementById('#form'), {
		fields: {
			repacking_date: {
				validators:{
					notEmpty:{
						message: 'Please select repacking date.'
					}
				}
			},
			work_type: {
				validators: {
					notEmpty: {
						message: 'Please select work type.'
					}
				}
			},
			contractor: {
				validators:{
					notEmpty:{
						message: 'Please select contractor.'
					}
				}
			},
			location:{
				validators: {
					notEmpty:{
						message: 'Please select location.'
					}
				}
			},
			activity:{
				validators: {
					notEmpty:{
						message: 'Please select activity.'
					}
				}
			},
			item:{
				validators: {
					notEmpty: {
						message: 'Please select item.'
					}
				}
			},
			uom: {
				validators: {
					notEmpty: {
						message: 'Please select uom.'
					}
				}
			},
			quantity:{
				validators: {
					notEmpty: {
						message: 'Please provide quantity.'
					}
				}
			},
			rate:{
				validators: {
					notEmpty: {
						message: 'Please provide rate.'
					}
				}
			},
			amount:{
				validators: {
					notEmpty: {
						message: 'Please provide amount.'
					}
				}
			},
		},
		plugins: {
			trigger: new FormValidation.plugins.Trigger(),
			bootstrap3: new FormValidation.plugins.Bootstrap3(),
			submitButton: new FormValidation.plugins.SubmitButton(),
			defaultSubmit: new FormValidation.plugins.DefaultSubmit(),
		},
	}).on('core.element.validated', function (e) {
		if (e.valid) {
			$('div#'+ e.field.replace('[]','') +'_chosen').removeClass('is-invalid');
			$('div#'+ e.field.replace('[]','') +'_chosen').addClass('is-valid');
		} else {
			$('div#'+ e.field.replace('[]','') +'_chosen').removeClass('is-valid');
			$('div#'+ e.field.replace('[]','') +'_chosen').addClass('is-invalid');
		}
	});
	$('#repacking_date').on('changeDate',function(){
		$('form').formValidation('revalidateField', $(this).attr('id'));
	});
</script>
