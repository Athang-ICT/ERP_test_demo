});
	$(document).on('change', '.tr_item', function() {
		var selectedItem = $(this).val(); // get the value of the changed .tr_item
		var relatedItemElement = $(this).closest('tr').find('.tr_uom'); // find the related .tr_uom in the same row
		
		// Assuming you want to do an AJAX call similar to what you've shown in your initial code:
		$.post(
			"<?php echo $this->url('purorder', array('action' => 'getuom')); ?>",
			{
				itemId: selectedItem,
			},
			function(data) {
				relatedItemElement.html(data.uom); // updating the related .tr_uom
				relatedItemElement.trigger('chosen:updated'); // if you're using chosen plugin
				
			},
			'json'
		);  
	});

	$(document).on('change', '.tr_item_class', function() {
		var selectedClass = $(this).val(); // get the value of the changed .tr_item
		var relatedItemElement = $(this).closest('tr').find('.tr_item'); // find the related .tr_item in the same row
		var subheadElement = $(this).closest('tr').find('.tr_subhead');
		var asst = $(this).closest('tr').find('#asst_container'); // find the related .tr_uom in the same row
		var items = $(this).closest('tr').find('#item_container'); // find the related .tr_uom in the same row
		$.post(
			"<?php echo $this->url('purorder', array('action' => 'getsubhead')); ?>",
			{
				itemclassId: selectedClass,
			},
			function(data) {
				console.log(data);
				subheadElement.html(data.subheadlist); // updating the related .tr_uom
				subheadElement.trigger('chosen:updated'); // if you're using chosen plugin
				
			},
			'json'
		);
		if(selectedClass==33){
			asst.show();
			items.hide();
		}
		else{
			asst.hide();
			items.show();

		// Assuming you want to do an AJAX call similar to what you've shown in your initial code:
		$.post(
			"<?php echo $this->url('purorder', array('action' => 'getitem')); ?>",
			{
				itemclassId: selectedClass,
			},
			function(data) {
				console.log(data);
				relatedItemElement.html(data.item); // updating the related .tr_uom
				relatedItemElement.trigger('chosen:updated'); // if you're using chosen plugin
				
			},
			'json'
		);
	}  
	});
	$(document).on('input', '.tr_amount,.tr_quantity', function () {
		calculateTotalAmount();
		});
	$(document).on('input', '.tr_rate, .tr_quantity', function() {
		calculateTotal($(this));
	});
	
	function calculateTotal(element) {
		console.log("calculateTotal ");
		var row = element.closest('tr');  // Get the closest table row

		var rateInput = row.find('.tr_rate');  // Adjusted these to use class selectors and scope within the row
		var quantityInput = row.find('.tr_quantity');
		var totalInput = row.find('.tr_amount'); // Assuming there's a field for the total amount with the class "tr_amount"

		var rate = parseFloat(rateInput.val()) || 0;
		var quantity = parseFloat(quantityInput.val()) || 0;
		var total = rate * quantity;

		totalInput.val(total.toFixed(2));  // Assuming you want to show up to two decimal places
		calculateTotalAmount();
	}
	
	function calculateTotalAmount() {
		console.log("calculateTotal amount");
		var total = 0.0;

		// Iterate over each amount input field in the table
		$('.tr_amount').each(function() {
			var amount = parseFloat($(this).val());
			if (!isNaN(amount)) { // Make sure it's a valid number
				total += amount;
			}
		});

		// Update the #total field with the new sum
		$('#po_amount').val(total.toFixed(2));
	}	
