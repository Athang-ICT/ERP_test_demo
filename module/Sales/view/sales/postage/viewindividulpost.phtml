<script>
$('document').ready(function(){
    $('#print').click(function() {
    // Hide elements you don't want to print
    $('.widget-toolbar').hide();
    $('.bulk-data-container').hide();
    $('.space').hide();

    // Create a print window
    var printWindow = window.open('', '', 'width=600,height=600');

    // Add CSS for smaller text size and reduced spacing
    // ... (your existing CSS code)

    printWindow.document.write('</head><body>');

    // Insert the HTML content generated by PHP
    printWindow.document.write('<?php echo $htmlContent; ?>');

    printWindow.document.write('</body></html>');
    printWindow.document.close();

    // Trigger printing
    printWindow.print();

    // Restore hidden elements
    $('.widget-toolbar').show();
    $('.bulk-data-container').show();
    $('.space').show();
});

});
  // Add the 'highlighted-row' class to odd rows using JavaScript
  var rows = document.querySelectorAll('tbody tr');
  for (var i = 0; i < rows.length; i++) {
    if (i % 2 === 0) {
      rows[i].classList.add('highlighted-row');
    }
  }
</script>