<script>
	$('document').ready(function () {
	
		$('#scope').on('change', function () {
			if ($(this).val() === '1') {
				$('div#international').hide();
				$('div#noninternational').show();
			} else {
				$('div#international').show();
				$('div#noninternational').hide();
			}
		});

		
		/**Show or Hide Advice of delivery fee field */
		$('input[name="btn"]').on('change', function () {
			if ($(this).val() === '1') {
				$('div#advice_fee').show();
			} else {
				$('div#advice_fee').hide();
			}
		});
		$('input[name="btn"]').trigger('change');
		$('input[name="btn1"]').on('change', function () {
			if ($(this).val() === '1') {
				$('div#prepaid').show();
			} else {
				$('div#prepaid').hide();
			}

		});
		$('input[name="btn1"]').trigger('change');
		$('input[name="btn2"]').on('change', function () {
			if ($(this).val() === '1') {
				$('div#insurance').show();
			} else {
				$('div#insurance').hide();
			}

		});
		$('input[name="btn2"]').trigger('change');

		$('input[type="checkbox"]').on('change', function () {
        if ($(this).is(':checked')) {
            const name = $(this).attr('name');
            const value = $(this).val();
            $(`input[name="${name}"][value="${value === "1" ? "0" : "1"}"]`).prop('checked', false);
        }
    });
	$('input[name="btn3"]').on('change', function () {
			if ($(this).val() === '1') {
				$('div#bulk').show();
				$('div#notbulk').hide();
			} else {
				$('div#bulk').hide();
				$('div#notbulk').show();
			}

		});
		$('input[name="btn3"]').trigger('change');
		$('select#scope').on('change', function () {
			$.post(
				"<?php echo $this->url('postage', array('action' => 'getservice')); ?>", {
				scopeId: $(this).val(),
			},
				function (data) {
					$('select#service').html(data.service);
					$('select#service').trigger('chosen:updated');
				},
				'json'
			);
		});
		$('select#service').on('change', function () {
			$.post(
				"<?php echo $this->url('postage', array('action' => 'getfees')); ?>", {
				service: $(this).val(),
			},
				function (data) {
					$('#advice_delivery_fee').val(data.advice_delivery_fee);
					$('#registration_fee').val(data.registration_fee);
					$('#transmission_fee').val(data.transmission_fee);
				},
				'json'
			);
		});
		$('select#country').on('change', function () {
			$.post(
				"<?php echo $this->url('masterpos', array('action' => 'getcity')); ?>",{
				countryId: $(this).val(),
			},
				function (data) {
					$('select#city').html(data.city);
					$('select#city').trigger('chosen:updated');
				},
				'json'
			);
		});
		$('select#po_name').on('change', function () {
			$.post(
				"<?php echo $this->url('postage', array('action' => 'getpostoffice')); ?>",{
				po_name: $(this).val(),
			},
				function (data) {
					$('#post_code').val(data.post_code);
				},
				'json'
			);
		});
		/**
		 * Checking limit  of weight  
		 */

		$('#service, #weight, #country,#city').on('input', function () {
			if ($('#country').val() > 0 && $('#city').val() > 0) {
				let serviceVal = parseInt($('#service').val(), 10);
				if ([4, 6, 13, 14, 15, 17, 18, 19, 25].includes(serviceVal)){	
					$.post(
						"<?php echo $this->url('postage', array('action' => 'getchecklimit1')); ?>", {
						service: $('#service').val(),
						weight: $('#weight').val(),
						country: $('#country').val(),
						city: $('#city').val(),
					},
						function (data) {
							$('#weight-message').text(data.message);
							$('#weight-message').css('color', data.fontColor);
							if (data.message === "Exceeded The Limit") {
								$('#postage_rate').hide();
								$('#saveButton').hide();
							} else {
								$('#postage_rate').show();
								$('#saveButton').show();
							}
						},
						'json'
					);
				}else{
					$.post(
						"<?php echo $this->url('postage', array('action' => 'getchecklimit')); ?>", {
						service: $('#service').val(),
						weight: $('#weight').val(),
					
					},
						function (data) {
							$('#weight-message').text(data.message);
							$('#weight-message').css('color', data.fontColor);
							if (data.message === "Exceeded The Limit") {
								$('#postage_rate').hide();
								$('#saveButton').hide();
							} else {
								$('#postage_rate').show();
								$('#saveButton').show();
							}
						},
						'json'
					);
				}
			} else {
				$.post(
					"<?php echo $this->url('postage', array('action' => 'getchecklimit')); ?>", {
					service: $('#service').val(),
					weight: $('#weight').val()
				},
					function (data) {
						$('#weight-message').text(data.message);
						$('#weight-message').css('color', data.fontColor);
						if (data.message === "Exceeded The Limit") {
								$('#postage_rate').hide();
								$('#saveButton').hide();
							} else {
								$('#postage_rate').show();
								$('#saveButton').show();
							}
					},
					'json'
				);
			}

		});
		/**
		 *End  Checking limit  of weight  
		 */

		/**
		 * Calculating the postage Rate  
		 */
		$('#service,#country,#city,#weight').on('input', function () {
			if ($('#country').val() > 0 && $('#city').val() > 0) {
				let serviceVal = parseInt($('#service').val(), 10);
				if ([4, 6, 13, 14, 15, 17, 18, 19, 25].includes(serviceVal)){
					$.post(
						"<?php echo $this->url('postage', array('action' => 'getpostagerate1')); ?>", {
						service: $('#service').val(),
						weight: $('#weight').val(),
						country: $('#country').val(),
						city: $('#city').val(),

					},
						function (data) {
							$('#postage_rate').val(data.postage_rate);
							//console.log(postage_rate);
							// Continue with the calculation using the retrieved postage_rate
							var postage_rate_val = parseFloat(data.postage_rate);
							calculateTotal(postage_rate_val);
						},
						'json'
					);
				}else{
					$.post(
						"<?php echo $this->url('postage', array('action' => 'getpostagerate')); ?>", {
