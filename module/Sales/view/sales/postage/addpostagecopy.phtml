				$('div#other_service').hide();
			} else {
				$('div#money_order').hide();
				$('div#other_service').show();
			}
		});
		

		/**calculation of total amount based on the given variables*
			 
			var postage_rate = $('#postage_rate');
			var transmission_fee = $('#transmission_fee');
			var other_charges=$('#other_charges');
			
			// Add an event listener for changes in the rate and quantity inputs
			postage_rate.on('input', calculateTotalMoneyOrder);
			transmission_fee.on('input', calculateTotalMoneyOrder);
			other_charges.on('input', calculateTotalMoneyOrder);
			
			// Trigger the calculateTotal function initially when the page loads
			calculateTotalMoneyOrder();
			// Function to calculate the total and update the total input field
			function calculateTotalMoneyOrder(postage_rate_val){
				var postage_rate_val = parseFloat(postage_rate.val().replace(',', '')) || 0;
				var transmission_fee_val = parseFloat(transmission_fee.val().replace(',', '')) || 0;
				var other_charges_val = parseFloat(other_charges.val().replace(',', '')) || 0;
				
			
			if (isNaN(other_charges_val)) {
				other_charges_val = 0;
			}
			if (isNaN(postage_rate_val)) {
				postage_rate_val = 0;
			}
			//console.log("Postage Rate:", postage_rate_val);
		
			var total = (postage_rate_val + transmission_fee_val + other_charges_val);
				// Check if the total is a valid number
				if (!isNaN(total)) {
					$('#total_amt').val(total.toFixed(2)); // Display the total with 2 decimal places
				}
			}
			
			 * End of Calculation
			 */
