		 *End  Checking limit  of weight  
		 */

		/**
		 * Calculating the postage Rate  :Bulk Booking
		 */
		$('#service,#country,#city,#weight').on('change', function (key) {
			if ($('#country').val() > 0 && $('#city').val() > 0) {
				let serviceVal = parseInt($('#service').val(), 10);
				if ([4, 6, 13, 14, 15, 17, 18, 19, 25].includes(serviceVal)){
					$.post(
						"<?php echo $this->url('postage', array('action' => 'getpostagerate1')); ?>", {
						service: $('#service').val(),
						weight: $('#weight').val(),
						country: $('#country').val(),
						city: $('#city').val(),

					},
						function (data) {
							$('#postage_rate').val(data.postage_rate);
							//console.log(postage_rate);
							// Continue with the calculation using the retrieved postage_rate
							var postage_rate_val = parseFloat(data.postage_rate);
							calculateTotal(postage_rate_val);
						},
						'json'
					);
				}else{
					$.post(
						"<?php echo $this->url('postage', array('action' => 'getpostagerate')); ?>", {
						service: $('#service').val(),
						weight: $('#weight').val(),
						
					},
						function (data) {
							$('#postage_rate').val(data.postage_rate);
							//console.log(postage_rate);
							// Continue with the calculation using the retrieved postage_rate
							var postage_rate_val = parseFloat(data.postage_rate);
							calculateTotal(postage_rate_val);
						},
						'json'
					);
				}	
			}  else {
				$.post(
					"<?php echo $this->url('postage', array('action' => 'getpostagerate')); ?>", {
					service: $('#service').val(),
					weight: $('#weight').val(),
					

				},
					function (data) {
						//console.log(data.postage_rate);
						$('#postage_rate').val(data.postage_rate);
						
						// Continue with the calculation using the retrieved postage_rate
						var postage_rate_val = parseFloat(data.postage_rate);
						calculateTotal(postage_rate_val);
					},
					'json'
				);
			}
		});
		/**
		 * End to Calculating the postage Rate  
		 */


		/**calculation of total amount based on the given variables**/

		var postage_rate = $('#postage_rate');
		var advice_delivery_fee = $('#advice_delivery_fee');
		var registration_fee = $('#registration_fee');
		var other_charges = $('#other_charges');
		var insurance_amt = $('#insurance_amt');
		var prepaid_mode = $('#prepaid_mode');
		var radio = $('input[name="btn"]');

		// Add an event listener for changes in the rate and quantity inputs
		postage_rate.on('input', calculateTotal);
		advice_delivery_fee.on('input', calculateTotal);
		registration_fee.on('input', calculateTotal);
		insurance_amt.on('input', calculateTotal);
		other_charges.on('input', calculateTotal);
		prepaid_mode.on('input', calculateTotal);
		radio.on('input', calculateTotal);

		// Trigger the calculateTotal function initially when the page loads
		calculateTotal();
		// Function to calculate the total and update the total input field
		function calculateTotal(postage_rate_val) {
			var postage_rate_val = parseFloat(postage_rate.val().replace(',', '')) || 0;
			var advice_delivery_fee_val = parseFloat(advice_delivery_fee.val().replace(',', '')) || 0;
			var registration_fee_val = parseFloat(registration_fee.val().replace(',', '')) || 0;
			var insurance_amt_val = parseFloat(insurance_amt.val().replace(',', '')) || 0;
			var other_charges_val = parseFloat(other_charges.val().replace(',', '')) || 0;
			var prepaid_mode_val = parseFloat(prepaid_mode.val().replace(',', '')) || 0;
			var radio_val = parseFloat(radio.filter(':checked').val());

			if (isNaN(insurance_amt_val)) {
				insurance_amt_val = 0;
			}
			if (isNaN(other_charges_val)) {
				other_charges_val = 0;
			}
			if (isNaN(radio_val)) {
				radio_val = 0;
			}
			if (isNaN(prepaid_mode_val)) {
				prepaid_mode_val = 0;
			}
			if (isNaN(advice_delivery_fee_val) || radio_val == 0) {
				advice_delivery_fee_val = 0;
			}
			if (isNaN(registration_fee_val)) {
				registration_fee_val = 0;
			}
			//console.log("Postage Rate:", postage_rate_val);

			var total = (postage_rate_val + advice_delivery_fee_val + registration_fee_val + insurance_amt_val +
				other_charges_val) - prepaid_mode_val;
			// Check if the total is a valid number
			if (!isNaN(total)) {
				$('#total_amt').val(total.toFixed(2)); // Display the total with 2 decimal places
			}
		}
		/**
		 * End of Calculation
		 */
		
		$('input[type=radio][name=cash]').change(function(){
        if ($(this).val() == "0") {
			$('#journal').show();
			 $('#phone').show();
			 $('#party').hide();
			 $('#ref_no').hide();
        } 
		else if($(this).val() == "1"){
			$('#journal').hide();
			 $('#phone').hide();
			 $('#party').hide();
			  $('#ref_no').hide();
			
		}else {
           $('#journal').hide();
			 $('#phone').hide();
			 $('#party').show();
			 $('#ref_no').show();
        } 
    });
	
	$('form input, form select').on('keydown', function (e) {
        // Check for the Enter key
        if (e.which === 13) {
            e.preventDefault(); // Prevent form submission

            // Get all input elements in form
            var inputs = $(this).closest('form').find(':input:visible:not([disabled])');

            // Find the next input element
            var nextInput = inputs.eq(inputs.index(this) + 1);
            
            if (nextInput.length) {
                nextInput.focus();
            } else {
                // If there's no next input, you might want to trigger form submission
                // $(this).closest('form').submit(); 
            }
        }
    });
