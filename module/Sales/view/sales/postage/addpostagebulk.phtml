							$('#weight-message').text(data.message);
							$('#weight-message').css('color', data.fontColor);
							if (data.message === "Exceeded The Limit") {
								$('#postage_rate').hide();
								$('#saveButton').hide();
							} else {
								$('#postage_rate').show();
								$('#saveButton').show();
							}
						},
						'json'
					);
				}else{
					$.post(
						"<?php echo $this->url('postage', array('action' => 'getchecklimit')); ?>", {
						service: $('#service').val(),
						weight: $('#weight').val(),
					
					},
						function (data) {
							$('#weight-message').text(data.message);
							$('#weight-message').css('color', data.fontColor);
							if (data.message === "Exceeded The Limit") {
								$('#postage_rate').hide();
								$('#saveButton').hide();
							} else {
								$('#postage_rate').show();
								$('#saveButton').show();
							}
						},
						'json'
					);
				}
			} else {
				$.post(
					"<?php echo $this->url('postage', array('action' => 'getchecklimit')); ?>", {
					service: $('#service').val(),
					weight: $('#weight').val()
				},
					function (data) {
						$('#weight-message').text(data.message);
						$('#weight-message').css('color', data.fontColor);
						if (data.message === "Exceeded The Limit") {
								$('#postage_rate').hide();
								$('#saveButton').hide();
							} else {
								$('#postage_rate').show();
								$('#saveButton').show();
							}
					},
					'json'
				);
			}

		});
