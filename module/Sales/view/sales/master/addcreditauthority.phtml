			<div class="panel-body">   
				<div class="form-group">
					<label for="authority" class="control-label">Authority</label>
					<input type="text" class="form-control" name="authority" id="authority" size="30" placeholder="Authority" required/> 
				</div>
				<div class="form-group">
					<label for="approval_limit" class="control-label">Approval Limit</label>
					<input type="text" class="form-control" name="approval_limit" id="approval_limit" size="30" placeholder="Approval Limit" required/> 
				</div>
				<div class="form-group">
