<script>
    document.addEventListener('DOMContentLoaded', function () {
        var amountFields = document.querySelectorAll('[name="renewal_amount"], [name="total_amount"]');
        amountFields.forEach(function (field) {
            field.addEventListener('input', function () {
                this.value = this.value.replace(/[^0-9.]/g, ''); // Allow only numeric and decimal values
            });
        });
    });
</script>
