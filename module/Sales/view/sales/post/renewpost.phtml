<script>
$('document').ready(function(){
	$('#renewal_date').datepicker();
	$('input[type=radio][name=cash]').change(function() {
		  $('#account_no_container').show();
	console.log($(this).val());
		$.post(
			"<?php echo $this->url('postbox', array('action' => 'getBCAccount')); ?>",
			{
				paymentId: $(this).val(),
				locationId: $('#location').val(),
			},
			function(data) {
				console.log(data);
				$("#account_no").html(data.account);	
				$("#account_no").trigger('chosen:updated');
			},
			'json'
		);

		if ($(this).val() == "0") {
			
			$('#journal').show();
			$('#ref_no').hide(); 
		} else {
			
			$('#journal').hide();
			$('#ref_no').hide();
		}
	});
	const fv = FormValidation.formValidation(document.getElementById('#form'), {
		fields: {
			post_box_size: {
				validators: {
					notEmpty: {
						message: 'Eneter Fuel'
					},
				}
			},
			cash: {
				validators: {
					notEmpty: {
						message: 'Please Select Payment Mode'
					},
				}
			},
            account_no: {
				validators: {
					notEmpty: {
						message: 'Please select Account'
					},
				}
			},
            renewal_amount: {
				validators: {
					notEmpty: {
						message: 'Enter the renewal amount'
					},
				}
			},
		},
		plugins: {
			trigger: new FormValidation.plugins.Trigger(),
			bootstrap3: new FormValidation.plugins.Bootstrap3(),
			submitButton: new FormValidation.plugins.SubmitButton(),
			defaultSubmit: new FormValidation.plugins.DefaultSubmit(),
		},
	}).on('core.element.validated', function (e) {
		if (e.valid) {
			$('div#'+ e.field.replace('[]','') +'_chosen').removeClass('is-invalid');
			$('div#'+ e.field.replace('[]','') +'_chosen').addClass('is-valid');
		} else {
			$('div#'+ e.field.replace('[]','') +'_chosen').removeClass('is-valid');
			$('div#'+ e.field.replace('[]','') +'_chosen').addClass('is-invalid');
		}
	});
	$('form select').chosen().change(function () {
		fv.revalidateField($(this).attr('name'));
	});
});
$('document').ready(function(){
    // Form validation setup (your existing code)
    const fv = FormValidation.formValidation(document.getElementById('#form'), {
        // Your validation rules...
    });

    // Event listener for 'Key Charges' and 'Rate' fields
    $('#key_charges, #rate').on('input', function() {
        // Get the values entered in 'Key Charges' and 'Rate' fields
        var keyCharges = parseFloat($('#key_charges').val()) || 0;
        var rate = parseFloat($('#rate').val()) || 0;

        // Calculate the total amount
        var amount = keyCharges + rate;

        // Update the 'Amount' field with the calculated value
        $('#amount').val(amount.toFixed(2)); // Ensure two decimal places
    });
});
</script>
