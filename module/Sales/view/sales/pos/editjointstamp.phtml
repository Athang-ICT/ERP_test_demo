	//on rate and quantity change, call calculateTotal()
	$(document).on('input', '.tr_quantity,.tr_rate', function() {
		calculateTotal($(this));
	});
		$(document).on('input', '.tr_amount,.tr_quantity', function () {
		calculateTotalAmount();
		calculateTotalNet();
		});

		//Calculate amount on rate and quantity change
	function calculateTotal(element) {
		var row = element.closest('tr');  // Get the closest table row

		var rateInput = row.find('.tr_rate');  // Adjusted these to use class selectors and scope within the row
		var quantityInput = row.find('.tr_quantity');
		var totalInput = row.find('.tr_amount'); // Assuming there's a field for the total amount with the class "tr_amount"

		var rate = parseFloat(rateInput.val()) || 0;
		var quantity = parseFloat(quantityInput.val()) || 0;
		var total = rate * quantity;

		totalInput.val(total.toFixed(2));  // Assuming you want to show up to two decimal places
	}

	$(document).on('input', '.tr_amount', function() {
		calculateTotalAmount();
		calculateTotalNet();
	});
	
	function calculateTotalAmount() {
		console.log("calculateTotal amount");
		var total = 0.0;

		// Iterate over each amount input field in the table
		$('.tr_amount').each(function() {
			var amount = parseFloat($(this).val());
			if (!isNaN(amount)) { // Make sure it's a valid number
				total += amount;
			}
		});

		// Update the #total field with the new sum
		$('#total').val(total.toFixed(2));
	}		
	function calculateTotalNet() {
		var total = 0.0;
		var discount=$('#discount').val();
		// Iterate over each amount input field in the table
		$('.tr_amount').each(function() {
			var amount = parseFloat($(this).val());
			if(discount!=0 && !isNaN(amount)){
				total += amount-(amount*(discount/100));
			}
			else if (!isNaN(amount)) { // Make sure it's a valid number
				total += amount;
			}
		});
		// Update the #total field with the new sum
		$('#net_amount').val(total.toFixed(2));
	}	
	
	$(document).on('input', '.tr_quantity', function() {
		// Fetch the entered quantity from the changed input
		var enteredQuantity = parseFloat($(this).val()) || 0;
		
		// Find the related stock quantity in the same row
		var stockQtyElement = $(this).closest('tr').find('.tr_stock_qty');
		var stockQty = parseFloat(stockQtyElement.val()) || 0;

		// Check if entered quantity exceeds stock quantity
		if (enteredQuantity > stockQty) {
			alert('Entered quantity exceeds available stock!');
			$(this).val(stockQty); // Reset to max available quantity (optional)
			// You might also want to add visual cues, like changing the background color
			$(this).css('background-color', '#FFCCCC');
		} else {
			$(this).css('background-color', ''); // Reset background color
		}

		calculateTotal($(this)); 
	});
