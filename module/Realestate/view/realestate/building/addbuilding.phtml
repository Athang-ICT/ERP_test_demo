    divtest.setAttribute('class', 'form-group removeclass' + room);
    
    divtest.innerHTML = 
		'<tr><td class="col-lg-3"><div class="form-group"><select name="floor[]" class="form-control tr_floor" data-placeholder="Select" required><option value="-1">Select<?php foreach($floor as $floors):?><option value="<?php echo $floors['id']; ?>"><?php echo $floors['floor']; ?></option><?php endforeach; ?></select></div></td><td class="col-lg-1"><div class="form-group"><input type="text" class="form-control tr_flat_no" id="flat_no" name="flat_no[]"  placeholder="Flat No"></div></td><td class="col-lg-2 input-cell"><div class="form-group"><input type="text" id="rent" name="rent[]" class="form-control tr_rent" placeholder="rent" required></div></td><td class="col-lg-2 input-cell"><div class="form-group"><select id="flat_status" name="flat_status[]" class="form-control tr_flat_status" data-placeholder="Select" required><option value=""></option><?php foreach($status as $staus):?><option value="<?php echo $staus['id']?>"><?php echo $staus['status']?></option><?php endforeach;?></select></div></td><td class="col-lg-1 input-cell"><div class="form-group"><input type="text" class="form-control tr_area" name="area[]" id="area" data-placeholder="Select" required ></div></td><td class="col-lg-3"><div class="form-group"><input type="text" class="form-control tr_remarks" id="remarks" placeholder="remarks" name="remarks[]"></div></td><td class="col-lg-1 input-cell"><div class="input-group-btn"><button class="btn btn-sm btn-danger" type="button" onclick="remove_floor_field(' + room + ');"><span class="glyphicon-minus" aria-hidden="true"></span></button></div></td><tr>';
		objTo.appendChild(divtest);
    
	}
	function remove_floor_field(rid) {
	$('.removeclass' + rid).remove();
	}
    $(function() {
		$('#location,#block').on('change', function(){
			//alert($(this).val());
			$.post(
				"<?php echo $this->url('building', array('action' => 'getbuilding')); ?>",
				{
					location_id: $('#location').val(),
					type: $('#block').val(),
				},
				function(data){
					console.log(data);
					$('#building').html(data.building);
					$('#building').trigger('chosen:updated');
				},
				'json'
			);
		});
		$('#location').trigger('change');
		$('select#region').on('change',function(){
			$.post(
				"<?php echo $this->url('building', array('action' => 'getlocation'));?>",
				{
					regId: $(this).val(),
				},
				function(data){
					$('select#location').html(data.location);
					$('select#location').trigger('chosen:updated');
				},
				'json'
			);
		});

	});
	
	$('form select').chosen();
	$('document').ready(function(){
		const fv = FormValidation.formValidation(document.getElementById('#form'), {
			fields: {
				block: {
					validators: {
						notEmpty: {
							message: 'Please select block.'
						}
					}
				},
				asset: {
					validators: {
						notEmpty: {
							message: 'Please provide asset.'
						}
					}
				},
				assetid: {
					validators: {
						notEmpty: {
							message: 'Please provide Asset id.'
						},
						numeric:{
							message: 'Enter a Figure Value'
						}
					}
				},
				region: {
					validators: {
						notEmpty: {
							message: 'Please provide Region.'
						}
					}
				},
				location: {
					validators: {
						notEmpty: {
							message: 'Please provide location.'
						},
						numeric:{
							message: 'Enter a Figure Value'
						}
					}
				},
			
			plugins: {
				trigger: new FormValidation.plugins.Trigger(),
				bootstrap3: new FormValidation.plugins.Bootstrap3(),
				submitButton: new FormValidation.plugins.SubmitButton(),
				defaultSubmit: new FormValidation.plugins.DefaultSubmit(),
			},
		}
		}).on('core.element.validated', function (e) {
			if (e.valid) {
				$('div#'+ e.field.replace('[]','') +'_chosen').removeClass('is-invalid');
				$('div#'+ e.field.replace('[]','') +'_chosen').addClass('is-valid');
			} else {
				$('div#'+ e.field.replace('[]','') +'_chosen').removeClass('is-valid');
				$('div#'+ e.field.replace('[]','') +'_chosen').addClass('is-invalid');
			}
		});
	});
</script>