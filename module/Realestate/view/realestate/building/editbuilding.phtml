	function remove_floor_field(rid) {
	$('.removeclass' + rid).remove();
	}
	
    $(function() {
		$('#location,#block').on('change', function(){
			//alert($(this).val());
			$.post(
				"<?php echo $this->url('building', array('action' => 'getbuilding')); ?>",
				{
					location_id: $('#location').val(),
					type: $('#block').val(),
				},
				function(data){
					console.log(data);
					$('#building').html(data.building);
					$('#building').trigger('chosen:updated');
				},
				'json'
			);
		});
		//$('#location').trigger('change');
		$('select#region').on('change',function(){
			$.post(
				"<?php echo $this->url('building', array('action' => 'getlocation'));?>",
				{
					regId: $(this).val(),
				},
				function(data){
					$('select#location').html(data.location);
					$('select#location').trigger('chosen:updated');
				},
				'json'
			);
		});

	});
	
	$('form select').chosen();
	$('document').ready(function(){
		const fv = FormValidation.formValidation(document.getElementById('#form'), {
			fields: {
				block: {
					validators: {
						notEmpty: {
							message: 'Please select block.'
						}
					}
				},
				asset: {
					validators: {
						notEmpty: {
							message: 'Please provide asset.'
						}
					}
				},
				assetid: {
					validators: {
						notEmpty: {
							message: 'Please provide Asset id.'
						},
						numeric:{
							message: 'Enter a Figure Value'
						}
					}
				},
				region: {
					validators: {
						notEmpty: {
							message: 'Please provide Region.'
						}
					}
				},
				location: {
					validators: {
						notEmpty: {
							message: 'Please provide location.'
						},
						numeric:{
							message: 'Enter a Figure Value'
						}
					}
				},
			
			plugins: {
				trigger: new FormValidation.plugins.Trigger(),
				bootstrap3: new FormValidation.plugins.Bootstrap3(),
				submitButton: new FormValidation.plugins.SubmitButton(),
				defaultSubmit: new FormValidation.plugins.DefaultSubmit(),
			},
		}
		}).on('core.element.validated', function (e) {
			if (e.valid) {
				$('div#'+ e.field.replace('[]','') +'_chosen').removeClass('is-invalid');
				$('div#'+ e.field.replace('[]','') +'_chosen').addClass('is-valid');
			} else {
				$('div#'+ e.field.replace('[]','') +'_chosen').removeClass('is-valid');
				$('div#'+ e.field.replace('[]','') +'_chosen').addClass('is-invalid');
			}
		});
	});
