				<?php endforeach; ?>
			</select>
		</div>
	</td>
	<td class="col-lg-1">
		<div class="form-group"><input type="text" class="form-control tr_flat_no" id="flat_no" name="flat_no[]"  placeholder="Flat No"></div>
		</td>
		<td class="col-lg-2 input-cell"><div class="form-group"><input type="text" id="rent" name="rent[]" class="form-control tr_rent" placeholder="rent" required></div>
		</td>
		<td class="col-lg-2 input-cell">
			<div class="form-group">
				<select id="flat_status" name="flat_status[]" class="form-control tr_flat_status" data-placeholder="Select" required>
