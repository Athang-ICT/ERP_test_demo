<script>
$('document').ready(function(){
	 $("#quantity").on('input',function() {
		 var enteredQuantity = parseFloat($(this).val()) || 0;
		  console.log('Quantity:', enteredQuantity);
		var stockQty = parseFloat($('#stock_qty').val());
	  //  var stockQty = parseFloat(stockQtyElement.val()) || 0;

		// Check if entered quantity exceeds stock quantity
		if (stockQty - enteredQuantity < 0){
			alert('Entered quantity exceeds available stock!');
			$(this).val(stockQty); // Reset to max available quantity (optional)
			// You might also want to add visual cues, like changing the background color
			$(this).css('background-color', '#FFCCCC');
		} else {
			$(this).css('background-color', ''); // Reset background color
		}
	});
	$("#item,#location").change(function() {
		$.post(
			"<?php echo $this->url('goodsrequest', array('action' => 'getuom'));?>",
			{
				itemId: $('#item').val(),
				locationId: $('#location').val(),
			},
			function(data){
				//console.log(data);	
				$('select#uom').html(data.uom);
				$('select#uom').trigger('chosen:updated');
				$('#stock_qty').val(data.quantity);
			},
			'json'
		);	
	});
	
	$('#location').trigger('change');
	const fv = FormValidation.formValidation(document.getElementById('#form'), {
		fields: {
			item: {
				validators: {
					notEmpty: {
						message: 'Please provide item.'
					}
				}
			},
			uom: {
				validators: {
					notEmpty: {
						message: 'Please provide UOM'
					},
				}
			},
		},
		plugins: {
			trigger: new FormValidation.plugins.Trigger(),
			bootstrap3: new FormValidation.plugins.Bootstrap3(),
			submitButton: new FormValidation.plugins.SubmitButton(),
			defaultSubmit: new FormValidation.plugins.DefaultSubmit(),
		},
	}).on('core.element.validated', function (e) {
		if (e.valid) {
			$('div#'+ e.field.replace('[]','') +'_chosen').removeClass('is-invalid');
			$('div#'+ e.field.replace('[]','') +'_chosen').addClass('is-valid');
		} else {
			$('div#'+ e.field.replace('[]','') +'_chosen').removeClass('is-valid');
			$('div#'+ e.field.replace('[]','') +'_chosen').addClass('is-invalid');
		}
	});
	$('form select').chosen().change(function () {
		fv.revalidateField($(this).attr('name'));
	});
});


</script>
