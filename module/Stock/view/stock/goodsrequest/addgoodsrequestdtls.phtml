        <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
        <h4 class="modal-title"> <i class="fa fa-asterisk"></i>Good Request Details</h4>
    </div>  <!-- /modal-header -->
    <div class="modal-body">
	<input type="hidden" name="gr_id" value=<?php echo $row['id']?>>
