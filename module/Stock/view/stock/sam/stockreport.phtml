						$todispatch=$this->dispatchObj->getSumto($row['location'],$row['item'],$data);
						//get dispatch for from location for current month and it is used for finding the closing stock
						$fromdispatch=$this->dispatchObj->getSumfrom($row['location'],$row['item'],$data);
						$dispatchpending=$this->dispatchObj->getSumPending($row['location'],$row['item'],$data);
						//get dispatch for from location for previous month and it is used for finding the opening stock
						$prefromdispatch=$this->dispatchObj->getPreSumfrom($row['location'],$row['item'],$data);
						$openingQty = $row['opening_qty'];
