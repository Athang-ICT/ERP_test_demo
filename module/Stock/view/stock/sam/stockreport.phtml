						if($itemgroup==64 || $itemgroup==67):
							$priceid= $this->priceObj->getMaxID('id',$data['start_date'],$data['end_date'],array('item'=>$row['item']));
							if(!empty($priceid)):
							$pid=$priceid;
							else:
							$pid= $this->priceObj->getMax('id',array('item'=>$row['item']));
							endif;
							//print_r($priceid);
							foreach($this->priceObj->get($pid) as $prices);
							$op=$prices['cost_price'];
							$cp=$prices['weighted_price'];
						else:
							$op=$row['cost_price'];
							$cp=$row['cost_price'];
						endif;
						//get dispatch for to location for previous month and it is used for finding the opening stock
						$pretodispatch=$this->dispatchObj->getPreSumto($row['location'],$row['item'],$data);
