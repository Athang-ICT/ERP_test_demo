				item_class: $(this).val(),
			},
			function(data){
				console.log(data);
				$("#group").html(data.subgroup);	
				$("#group").trigger('chosen:updated');
			},
			'json'
		);	
	});
	$('#group,#location').on('change', function(){
		//alert($(this).val());
		$.post(
			"<?php echo $this->url('sam', array('action' => 'getItemChange')); ?>",
			{
				locationId: $("#location").val(),
				item_subgroup: $("#group").val(),
			},
			function(data){
				console.log(data);
				$("#item").html(data.items);	
				$("#item").trigger('chosen:updated');
			},
			'json'
		);	
	});
});
</script>

