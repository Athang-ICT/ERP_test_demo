						$current_pur=$this->purchaseObj->getSumCurrent(array('p.location'=>$row['location'],'pd.item'=>$row['item'],'p.status'=>4),$data);
						$pre_pur=$this->purchaseObj->getSumPre($row['location'],$row['item'],$data);
