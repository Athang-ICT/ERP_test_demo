//CALCULATE DEBIT ON GETVPREV DATA
function calculateTotalDebit() {
  var totalDebit = 0;
  $('.tr_debit').each(function () {
    var debit = parseFloat($(this).val());
    if (!isNaN(debit)) {
      totalDebit += debit;
    }
  });
  $('#total_debit').val(totalDebit.toFixed(2)).trigger('change');
  $('#voucher_amount').val(totalDebit.toFixed(2)).trigger('change');
}
//CALCULATE CREDIT ON FORM INPUT
function calculateTotalCredit() {
  var totalCredit = 0;
  $('.tr_credit').each(function () {
    var credit = parseFloat($(this).val());
    if (!isNaN(credit)) {
      totalCredit += credit;
    }
  });
  $('#total_credit').val(totalCredit.toFixed(2)).trigger('change');
}
function calculateTotalCommission() {
  var totalCommission = 0;
  var totalCredit = 0;
  $('.tr_credit').each(function () {
    var credit = parseFloat($(this).val());
    if (!isNaN(credit)) {
      totalCredit += credit;
    }
  });
  $('.tr_commission').each(function () {
    var commission = parseFloat($(this).val());
    if (!isNaN(commission)) {
      totalCommission += commission;
	  updateCredit = totalCommission + totalCredit;
    }
  });
  $('#total_commission').val(totalCommission.toFixed(2)).trigger('change');
  $('#total_credit').val(updateCredit.toFixed(2)).trigger('change');
}
function calculateTotalDecimal() {
  var totalDecimal = 0;
  var totalCredit = 0;
  var totalCommission = 0;
   $('.tr_credit').each(function () {
    var credit = parseFloat($(this).val());
    if (!isNaN(credit)) {
      totalCredit += credit;
    }
  });
  $('.tr_commission').each(function () {
    var commission = parseFloat($(this).val());
    if (!isNaN(commission)) {
      totalCommission += commission;
    }
  });
 
  $('.tr_decimal').each(function () {
    var decimal = parseFloat($(this).val());
    if (!isNaN(decimal)) {
      totalDecimal += decimal;
	   updateCredit = totalCommission + totalCredit + totalDecimal;
    }
  });
  $('#total_decimal').val(totalDecimal.toFixed(2)).trigger('change');
  $('#total_credit').val(updateCredit.toFixed(2)).trigger('change');
}
function calculateTotalRemitance() {
  var totalRemitance = 0;
  var totalDecimal = 0;
  var totalCommission = 0;
  $('.tr_commission').each(function () {
    var commission = parseFloat($(this).val());
    if (!isNaN(commission)) {
      totalCommission += commission;
    }
  });
 
  $('.tr_decimal').each(function () {
    var decimal = parseFloat($(this).val());
    if (!isNaN(decimal)) {
      totalDecimal += decimal;
    }
  });
  $('.tr_remitance').each(function () {
    var remitance = parseFloat($(this).val());
    if (!isNaN(remitance)) {
      totalRemitance += remitance;
	  actualCommission = (totalCommission + totalDecimal) - totalRemitance;
    }
  });
  $('#total_remitance').val(totalRemitance.toFixed(2)).trigger('change');
  $('#actual_commission').val(actualCommission.toFixed(2)).trigger('change');
}
$('#education_field').on('change', '.tr_debit', function () {
  calculateTotalDebit();
});
$('#education_field').on('change', '.tr_credit', function () {
  calculateTotalCredit();
});

$('#education_field').on('keyup', '.tr_commission', function () {
  calculateTotalCommission();
});
$('#education_field').on('keyup', '.tr_decimal', function () {
  calculateTotalDecimal();
});
$('#education_field').on('keyup', '.tr_remitance', function () {
  calculateTotalRemitance();
});

$(document).ready(function (){
  $('#voucher_date').datepicker();
  calculateTotalDebit(); // Calculate initial total debit
  calculateTotalCredit();// Calculate initial total credit
  calculateTotalRemitance();
  calculateTotalCommission();
  calculateTotalDecimal();

  $('#education_field').on('change', '.tr_debit', function () {
    calculateTotalDebit(); // Recalculate total debit on any change
  });
  $('#education_field').on('change', '.tr_credit', function () {
	calculateTotalCredit(); // Recalculate total credit on any change
  });
   $('#education_field').on('keyup', '.tr_remitance', function () {
	calculateTotalRemitance();
  });
   $('#education_field').on('keyup', '.tr_commission', function () {
	calculateTotalCommission();
  });
   $('#education_field').on('keyup', '.tr_decimal', function () {
	calculateTotalDecimal();
  });
  
  $('#vno').on('change', function () {
    $.post(
      '<?php echo $this->url('transaction', array('action' => 'getvprev')); ?>',
	 
      {
        id: $(this).val(),
      },
      function (data) {
        console.log(data);
        $('#location').val(data.loc);
        $("#location").trigger('chosen:updated');
        $('#head').val(data.head);
        $("#head").trigger('chosen:updated');
        $('#sub_head').val(data.subhead);
        $("#sub_head").trigger('chosen:updated');
		//CREDIT of previous voucher becomes debit(debit==credit)
        $('#credit').val(data.credit);
        $("#credit").trigger('chosen:updated');
		$('#vid').val(data.vid);
        $("#vid").trigger('chosen:updated');
        calculateTotalDebit(); // Recalculate total debit
		calculateTotalCredit();
      },
      'json'
    );
  });
});

$('#head').on('change', function() {
  var headId = $(this).val();

  // Perform the AJAX post request to retrieve the subhead options
  $.post(
    '<?php echo $this->url('transaction', array('action' => 'getSubheads')); ?>',
    { headId: headId },
    function(data) {
      console.log('AJAX response:', data);

      var subHeadSelect = $('#sub_head'); // Select element
      subHeadSelect.empty(); // Clear existing options

      // Construct and append new options based on the AJAX response
      $.each(data.subhead, function(index, option) {
        subHeadSelect.append($('<option>', {
          value: option.value,
          text: option.text
        }));
      });

      // Trigger chosen:updated event to update the chosen select plugin
      subHeadSelect.trigger('chosen:updated');
    },
    'json' // Specify the expected response type as JSON
  );
});
