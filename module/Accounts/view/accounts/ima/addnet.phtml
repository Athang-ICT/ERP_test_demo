group"><input type="text" class="form-control tr_rate" name="rate[]" id="rate" value="0.000"/></div></td><td class="col-lg-1 input-cell"><div class="form-group"><input type="text" class="form-control tr_debit" name="debit[]"  value="" id="debit" ></div></td><td class="col-lg-1 input-cell"><div class="form-group"><input type="text" class="form-control tr_credit" name="credit[]"  value="" id="credit" ></div></td><td class="col-lg-1 input-cell"><div class="form-group"><input type="text" class="form-control tr_ref" name="ref[]"  value="" id="ref" ></div></td><td class="col-lg-1 input-cell"><div class="input-group-btn"><button class="btn btn-sm btn-danger" type="button" onclick="remove_net_field(' + room + ');"><span class="glyphicon-minus" aria-hidden="true"></span></button></div></td></tr>';
