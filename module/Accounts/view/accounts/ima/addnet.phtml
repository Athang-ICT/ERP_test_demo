		//var relatedItemElement2 = $(this).closest('tr').find('.tr_curreny'); // find the related .tr_referencein the same row
		var relatedItemElement3 = $(this).closest('tr').find('.tr_amount_usd'); // find the related .tr_referencein the same row
		var relatedItemElement4 = $(this).closest('tr').find('.tr_rate'); // find the related .tr_referencein the same row
		console.log(selectedref);
		$.post(
			"<?php echo $this->url('ima', array('action' => 'getcdamount')); ?>",
			{
				ref: selectedref,
			},
			function(data){
				console.log(data);
				relatedItemElement.val(data.debit); // updating the related .tr_subhead
				relatedItemElement1.val(data.credit); // updating the related .tr_subhead
				//relatedItemElement2.val(data.currency); // updating the related .tr_subhead
				relatedItemElement3.val(data.totalsdr); // updating the related .tr_subhead
				relatedItemElement4.val(data.rate); // updating the related .tr_subhead
				calculateTotalCD();
			},
			'json'
			);
		});
		function calculateTotalCD() {
		//console.log("calculateTotal amount");
		var credit = 0.0;
		var debit=0.0;
		// Iterate over each amount input field in the table
		$('.tr_credit').each(function() {
			var amount = parseFloat($(this).val());
			if (!isNaN(amount)) { // Make sure it's a valid number
				credit += amount;
			}
		});
		// Update the #total field with the new sum
		$('#total_credit').val(credit.toFixed(2));
		
		// Iterate over each amount input field in the table
		$('.tr_debit').each(function() {
			var amount1 = parseFloat($(this).val());
			if (!isNaN(amount1)) { // Make sure it's a valid number
				debit += amount1;
			}
		});
		$('#total_debit').val(debit.toFixed(2));
		
	}
	$(document).on('input', '.tr_amount_usd,.tr_rate', function () { 
		calculateTotal($(this));
		});
		$(document).on('input', '.tr_credit,.tr_debit', function () {
			calculateTotalCD();
		});
		function calculateTotal(element) {
		var row = element.closest('tr');  // Get the closest table row

		var sdrInput = row.find('.tr_amount_usd');  // Adjusted these to use class selectors and scope within the row
		var rateInput = row.find('.tr_rate');
		var creditInput = row.find('.tr_credit'); // Assuming there's a field for the total amount with the class "tr_amount"
		var debitInput = row.find('.tr_debit'); 

		var sdr = parseFloat(sdrInput.val()) || 0;
		var rate = parseFloat(rateInput.val()) || 0;
	
		var total=sdr*rate;

		creditInput.val(total.toFixed(2));  // Assuming you want to show up to two decimal places
		debitInput.val(total.toFixed(2)); 
		calculateTotalCD();
	}
