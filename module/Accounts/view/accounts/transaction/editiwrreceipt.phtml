function handleChange(event) {
  console.log('handleChange event triggered');
  
  var inputElement = event.target;
  var row = inputElement.closest('tr');
  var inputs = row.querySelectorAll('input:not(.vno)');
  var selects = row.querySelectorAll('select.vno');
  
  // Perform the AJAX post request to retrieve data
  console.log('on change select vno');
  $.post(
    '<?php echo $this->url('transaction', array('action' => 'getvprev')); ?>',
    {
      id: inputElement.value
    },
    function (data) {
        console.log('AJAX response:', data);
		// Update the remaining inputs with the fetched data
		$(inputElement).closest('tr').find('select.tr_location').val(data.loc).trigger('change');
		$(inputElement).closest('tr').find('.tr_head').val(data.head);
		$(inputElement).closest('tr').find('.tr_subhead').val(data.subhead);
		$(inputElement).closest('tr').find('.tr_credit').val(data.credit);
		calculateTotalDebit();
		calculateTotalCredit();
    },
    'json'
  );
}
